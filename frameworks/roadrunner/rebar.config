{erl_opts, [debug_info]}.

{minimum_otp_vsn, "29"}.

{deps, [
    {roadrunner, {git, "https://github.com/arizona-framework/roadrunner.git", {branch, "feat/http3"}}},
    %% Override roadrunner's transitive hex quic with the patched fork branch
    %% (QPACK field-section prefix + dynamic-table fixes) until they land in a
    %% release. A top-level dep wins over the transitive one.
    {quic, {git, "https://github.com/williamthome/erlang_quic.git", {branch, "fix/qpack-dynamic-table"}}},
    {epgsql, "4.8.0"},
    {pooler, "1.6.0"}
]}.

{relx, [
    {release, {roadrunner_httparena, "0.1.0"},
        %% `quic` is an optional roadrunner runtime dep (started on demand
        %% for HTTP/3, not in roadrunner's `applications`), so a release
        %% using http3 must include it explicitly or the h3 listener fails
        %% with `{quic, "no such file or directory"}` at boot.
        [roadrunner_httparena, roadrunner, quic]},
    {sys_config, "./config/sys.config"},
    {dev_mode, false},
    {include_erts, true},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [
        {relx, [{mode, prod}]}
    ]}
]}.
